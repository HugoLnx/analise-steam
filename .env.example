# Use este arquivo como referência para variáveis de ambiente no Docker Compose.
# (O compose já injeta VITE_API_BASE_URL e CORS_ALLOWED_ORIGINS, mas aqui vai um exemplo.)

# Backend Django (CORS)
# Exemplo (comma-separated):
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://frontend:5173"

# Frontend Vite (API base)
VITE_API_BASE_URL="http://backend:8000"

